<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#EAF4E2">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        app:title="Expense"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Scroll content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollRoot"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/contentRoot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Type Toggle -->
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleType"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Switch to Income button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnIncome"
                    style="?attr/materialButtonOutlinedStyle"
                    android:backgroundTint="@color/toggle_button_income"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Income"
                    android:textColor="@color/text_color_toggle_button"
                    app:strokeWidth="0dp"/>

                <!-- Switch to Expense button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnExpense"
                    style="?attr/materialButtonOutlinedStyle"
                    android:backgroundTint="@color/toggle_button_expense"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Expense"
                    app:strokeWidth="0dp"
                    android:textColor="@color/text_color_toggle_button"/>

                <!-- Switch to Transfer button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTransfer"
                    style="?attr/materialButtonOutlinedStyle"
                    android:backgroundTint="@color/toggle_button_transfer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Transfer"
                    app:strokeWidth="0dp"
                    android:textColor="@color/text_color_toggle_button"/>

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- Date & Time -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDateTime"
                style="?attr/materialButtonOutlinedStyle"
                android:backgroundTint="@color/white"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="20/02/2026 • Friday • 23:01"
                app:icon="@drawable/ic_calendar"
                app:iconPadding="10dp"
                app:strokeWidth="0dp"
                app:layout_constraintTop_toBottomOf="@id/toggleType"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Amount -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilAmount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:prefixText="RM "
                app:layout_constraintTop_toBottomOf="@id/btnDateTime"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etAmount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Amount"
                    android:textSize="16sp"
                    android:background="@color/white"
                    android:inputType="numberDecimal"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Fee row for Transfer -->
            <LinearLayout
                android:id="@+id/feeRow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/tilAmount"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchFee"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Add fee (optional)" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilFee"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:visibility="gone"
                    app:prefixText="RM ">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etFee"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Fee amount"
                        android:background="@color/white"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- Income/Expense block -->
            <LinearLayout
                android:id="@+id/blockIncomeExpense"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/feeRow"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Category -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSelectCategory"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Category"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:gravity="start|center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/white"

                    style="?attr/materialButtonOutlinedStyle"
                    app:strokeWidth="0dp"
                    app:cornerRadius="4dp"
                    app:iconGravity="textEnd"
                    app:iconPadding="8dp"/>

                <!-- Account -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSelectAccount"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:text="Account"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:gravity="start|center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/white"

                    style="?attr/materialButtonOutlinedStyle"

                    app:strokeWidth="0dp"
                    app:cornerRadius="4dp"
                    app:iconGravity="textEnd"
                    app:iconPadding="8dp"/>

            </LinearLayout>

            <!-- Transfer block -->
            <LinearLayout
                android:id="@+id/blockTransfer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/feeRow"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- From -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilFrom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="From">

                    <AutoCompleteTextView
                        android:id="@+id/actvFrom"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:padding="12dp"
                        android:textSize="16sp"
                        android:background="@color/white"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- To -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilTo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="To">

                    <AutoCompleteTextView
                        android:id="@+id/actvTo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:padding="12dp"
                        android:textSize="16sp"
                        android:background="@color/white"/>
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/barrierAfterTypeBlock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="blockIncomeExpense,blockTransfer" />

            <!-- Note -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilNote"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Note"
                app:layout_constraintTop_toBottomOf="@id/barrierAfterTypeBlock"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="2"
                    android:textSize="16sp"
                    android:background="@color/white"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Description -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilDescription"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="Description"
                app:endIconMode="custom"
                app:layout_constraintTop_toBottomOf="@id/tilNote"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="3"
                    android:textSize="15sp"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:background="@color/white"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Buttons -->
            <LinearLayout
                android:id="@+id/actionRow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:weightSum="3"
                app:layout_constraintTop_toBottomOf="@id/tilDescription"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <!-- weightSum helps in space division -->
                <!-- layout_width must 0 or else it bugs -->
                <!-- Save button takes 2/3 space -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSave"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:layout_marginStart="10dp"
                    android:text="Save"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="8dp"/>

                <!-- Cancel button takes 1/3 space -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancel"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cancel"
                    app:cornerRadius="8dp"/>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
