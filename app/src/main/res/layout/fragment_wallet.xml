<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/walletRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ECFFDC"
    android:padding="16dp">

    <!-- 1) <   Month Year   > -->
    <LinearLayout
        android:id="@+id/monthRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnPrevMonth"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="8dp"
            android:background="@android:color/transparent"
            android:contentDescription="Previous month"
            android:src="@drawable/ic_btn_prev" />

        <TextView
            android:id="@+id/tvMonthYear"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="February 2026"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnNextMonth"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="8dp"
            android:background="@android:color/transparent"
            android:contentDescription="Next month"
            android:src="@drawable/ic_btn_next" />
    </LinearLayout>

    <!-- 2) Container for icon + toggle -->
    <LinearLayout
        android:id="@+id/llMenu"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/monthRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Toggle Group -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/togglePeriod"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDaily"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/toggle_button_bg"
                android:text="Daily" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMonthly"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/toggle_button_bg"
                android:text="Monthly" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- Right ImageButton -->
        <ImageButton
            android:id="@+id/btnStatistics"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_rounded_border"
            android:src="@drawable/ic_stats"
            android:elevation="3dp"
            android:translationZ="3dp"
            android:contentDescription="Statistics"
            android:padding="8dp"
            android:layout_marginEnd="14dp"/>

        <ImageButton
            android:id="@+id/btnBalances"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_rounded_border"
            android:src="@drawable/ic_balances"
            android:elevation="3dp"
            android:translationZ="3dp"
            android:contentDescription="Account Balances"
            android:padding="8dp"
            android:layout_marginEnd="4dp"/>

    </LinearLayout>

    <!-- 3) Income / Expense / Total -->
    <LinearLayout
        android:id="@+id/summaryRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:weightSum="3"
        app:layout_constraintTop_toBottomOf="@id/llMenu"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Income -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Income"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvIncome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RM 0.00"
                android:textSize="16sp"
                android:textColor="@color/income"
                android:textStyle=""/>
        </LinearLayout>

        <!-- Expense -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Expense"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvExpense"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RM 0.00"
                android:textSize="16sp"
                android:textColor="@color/expense"/>
        </LinearLayout>

        <!-- Total -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RM 0.00"
                android:textSize="16sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- List of sections + details -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvWallet"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/summaryRow"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="Add Expense"
        android:src="@drawable/ic_add"
        app:backgroundTint="@color/coral_pink"
        app:tint="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="10dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>