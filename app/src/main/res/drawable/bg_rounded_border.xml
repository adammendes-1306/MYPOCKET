<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background fill -->
    <solid android:color="@android:color/white"/>

    <!-- Border -->
    <stroke
        android:width="1dp" />

    <!-- Rounded corners -->
    <corners android:radius="12dp"/>

    <!-- Optional padding inside -->
    <padding
        android:left="8dp"
        android:top="4dp"
        android:right="8dp"
        android:bottom="4dp"/>


</shape>
